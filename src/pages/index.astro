---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/sections/hero.astro";
import Work from "../components/sections/work.astro";
import Services from "../components/sections/services.astro";
import Who from "../components/sections/who.astro";
import Process from "../components/sections/process.astro";
import Testimonials from "../components/sections/testimonials.astro";
import CTA from "../components/sections/cta.astro";
---

<MainLayout>
  <Hero />
  <Work />
  <Services />
  <Who />
  <Process />
  <Testimonials />
  <CTA />
  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import SplitType from "split-type";

    gsap.registerPlugin(ScrollTrigger);

    (() => {
      const elements = document.querySelectorAll("[data-animate='fade']");
      elements.forEach((element) => {
        gsap.from(element, {
          opacity: 0.2,
          scale: 0.98,
          filter: "blur(2px)",
          scrollTrigger: {
            trigger: element,
            start: "top 85%",
            end: "bottom 85%",
            scrub: 0.5,
          },
        });
      });
    })();

    (() => {
      const elements = Array.from(
        document.querySelectorAll("[data-animate='text']")
      ) as HTMLElement[];

      new SplitType(elements, {
        types: "lines,words,chars",
        tagName: "span",
      });

      elements.forEach((element) => {
        gsap.from(element.querySelectorAll(".char"), {
          scrollTrigger: {
            trigger: element,
            start: "top 65%",
            end: "bottom 65%",
            scrub: 0.5,
          },
          opacity: 0.15,
          stagger: 0.05,
        });
      });
    })();
  </script>
</MainLayout>
