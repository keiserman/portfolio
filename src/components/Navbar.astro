---
import Logo from "./Logo.astro";
import Button from "./Button.astro";
---

<header class="w-full py-4 fixed top-0 z-50 backdrop-blur-md bg-black/80 border-b border-zinc-800/50">
  <div class="padding-global">
    <div class="container flex items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-2 text-white tracking-wide">
        <div class="bg-zinc-800 p-2 rounded"><Logo /></div>Kevin Eiserman
      </a>
      <div id="nav-menu" class="md:block hidden grow">
        <div
          class="md:flex md:flex-row md:relative md:p-0 gap-4 md:items-center md:top-0 md:right-0 md:bg-transparent bg-zinc-900 flex flex-col absolute top-20 right-[5%] p-6 rounded z-30 md:shadow-none shadow-lg border border-zinc-800 md:border-none"
        >
          <div class="flex md:flex-row flex-col md:gap-6 gap-3 grow justify-end">
            <a href="#work" class="navbar-link">Work</a>
            <a href="#services" class="navbar-link">Services</a>
            <a href="#process" class="navbar-link">Process</a>
            <a href="#testimonials" class="navbar-link">Testimonials</a>
          </div>
          <Button url="mailto:hello@kevineiserman.com" text="Get in touch" variant="secondary" />
        </div>
      </div>
      <div class="flex gap-4 items-center">
        <div id="hamburger" class="flex flex-col gap-1.5 md:hidden z-50 cursor-pointer">
          <span data-hamburger="top" class="w-6 h-0.5 bg-white transition"></span>
          <span data-hamburger="middle" class="w-6 h-0.5 bg-white transition"></span>
          <span data-hamburger="bottom" class="w-6 h-0.5 bg-white transition"></span>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const navMenu = document.querySelector("#nav-menu");
  const hamburger = document.querySelector("#hamburger");
  const hamburgerTop = document.querySelector("[data-hamburger='top']");
  const hamburgerMiddle = document.querySelector("[data-hamburger='middle']");
  const hamburgerBottom = document.querySelector("[data-hamburger='bottom']");

  hamburger?.addEventListener("click", () => {
    navMenu?.classList.toggle("hidden");
    hamburgerTop?.classList.toggle("rotate-45");
    hamburgerTop?.classList.toggle("translate-y-[400%]");
    hamburgerMiddle?.classList.toggle("scale-x-0");
    hamburgerBottom?.classList.toggle("-rotate-45");
    hamburgerBottom?.classList.toggle("-translate-y-[400%]");
  });
</script>
