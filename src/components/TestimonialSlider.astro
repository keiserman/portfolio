---
import "swiper/css";
import SwiperNav from "./SwiperNav.astro";
import { Icon } from "astro-icon/components";
import { sanityClient } from "../lib/sanity";

const testimonials = await sanityClient.fetch(`*[_type == "testimonial"] | order(order asc) { name, role, text }`);
---

<div class="swiper overflow-hidden" id="testimonial-swiper">
  <div class="swiper-wrapper">
    {
      testimonials.map((testimonial: any) => (
        <div class="swiper-slide !h-auto">
          <div class="card flex flex-col justify-between gap-8 h-full">
            <div class="flex flex-col gap-6">
              <Icon name="lucide:quote" class="icon" />
              <p class="text-base text-zinc-400 leading-relaxed">{testimonial.text}</p>
            </div>
            <div class="flex flex-col gap-1">
              <div class="text-base font-medium">{testimonial.name}</div>
              <div class="text-sm text-zinc-400">{testimonial.role}</div>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</div>

<div class="flex items-center justify-between mt-6">
  <div class="flex gap-2">
    <SwiperNav name="testimonial" />
  </div>
  <div id="testimonial-pagination" class="flex gap-2 items-center"></div>
</div>

<script>
  import Swiper from "swiper";
  import { Navigation, Pagination } from "swiper/modules";

  new Swiper("#testimonial-swiper", {
    modules: [Navigation, Pagination],
    slidesPerView: 1,
    spaceBetween: 16,
    breakpoints: {
      768: {
        slidesPerView: 2,
      },
    },
    navigation: {
      prevEl: "#testimonial-prev",
      nextEl: "#testimonial-next",
    },
    pagination: {
      el: "#testimonial-pagination",
      clickable: true,
      renderBullet: (_index, className) => `<button class="${className}"></button>`,
    },
  });
</script>
