---
const { text, variant, url, ...rest } = Astro.props;
const isSecondary = variant === "secondary";
---

<a
  href={url}
  class={`px-5 py-3.5 rounded-full inline-flex self-start items-center gap-2 font-mono text-xs uppercase leading-none tracking-wider shadow-sm transition ${
    isSecondary
      ? "bg-transparent text-zinc-100 border border-zinc-600 hover:bg-white hover:text-zinc-950 hover:border-white"
      : "bg-white text-zinc-950 border-none hover:bg-zinc-200"
  }`}
  data-value={text}
  {...rest}
>
  <span data-scramble-text>{text}</span>
  <slot />
</a>

<script>
  const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";

  function scrambleText(button: HTMLElement & { _interval?: ReturnType<typeof setInterval> }) {
    const textEl = button.querySelector<HTMLElement>("[data-scramble-text]");
    if (!textEl) return;
    let iteration = 0;
    const originalText = button.dataset.value ?? "";
    let interval = setInterval(() => {
      textEl.textContent = originalText
        .split("")
        .map((letter, index) => {
          if (index < iteration) return originalText[index];
          return letters[Math.floor(Math.random() * 26)];
        })
        .join("");
      if (iteration >= originalText.length) clearInterval(interval);
      iteration += 1 / 3;
    }, 30);
    button._interval = interval;
  }

  function restoreText(button: HTMLElement & { _interval?: ReturnType<typeof setInterval> }) {
    clearInterval(button._interval);
    const textEl = button.querySelector<HTMLElement>("[data-scramble-text]");
    if (textEl) textEl.textContent = button.dataset.value ?? "";
  }

  document.querySelectorAll<HTMLElement>("a[data-value]").forEach((button) => {
    button.addEventListener("mouseenter", () => scrambleText(button as any));
    button.addEventListener("mouseleave", () => restoreText(button as any));
  });
</script>
