---
import Button from "../Button.astro";
import { Icon } from "astro-icon/components";
---

<section class="section bg-zinc-950 text-white">
  <div class="padding-global">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-16 items-start">
        <div class="flex flex-col gap-8 md:sticky top-1/4">
          <div class="flex flex-col gap-4">
            <p class="text-zinc-400 font-mono text-sm uppercase tracking-widest">Who I work with</p>
            <h2>Built for agencies.<br />Not end clients.</h2>
          </div>
          <div class="flex">
            <Button url="mailto:hello@kevineiserman.com" text="Start a project"><Icon name="lucide:arrow-right" class="size-4" /></Button>
          </div>
        </div>
        <div class="flex flex-col gap-10">
          <p class="text-lg text-zinc-400 leading-relaxed">
            I work exclusively with design agencies, studios, and freelance designers who need a reliable Webflow developer in their corner.
            I don't take on direct client work — I'm the developer behind your team.
          </p>
          <div class="flex flex-col gap-4">
            {
              [
                "You've got a Figma file ready and need it built right",
                "Your client needs Webflow and you need a dev partner",
                "You want someone who understands Client-First and won't ask basic questions",
                "You need a developer who communicates clearly and ships on time",
                "You're working on an enterprise project that needs real technical depth",
              ].map((item) => (
                <div class="flex items-start gap-4 py-4 border-t border-zinc-800">
                  <span class="text-white mt-0.5 shrink-0">→</span>
                  <p class="text-zinc-300">{item}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
