---
import { Icon } from "astro-icon/components";
---

<section id="services" class="section bg-zinc-900 text-white">
  <div class="padding-global">
    <div class="container">
      <div class="flex flex-col gap-4 mb-16">
        <p class="text-zinc-400 font-mono text-sm uppercase tracking-widest">Capabilities</p>
        <h2>What I build</h2>
      </div>
      <div class="grid md:grid-cols-2 grid-cols-1 gap-4">
        <div class="card flex flex-col">
          <Icon name="lucide:monitor" class="icon mb-8" />
          <div class="flex flex-col gap-2">
            <h3>Webflow Development</h3>
            <p class="text-zinc-400 leading-relaxed">
              End-to-end Webflow builds — from landing pages to complex multi-page sites with CMS, e-commerce, and custom logic. I build
              production-ready sites, not templates.
            </p>
          </div>
        </div>
        <div class="card flex flex-col">
          <Icon name="lucide:sparkles" class="icon mb-8" />
          <div class="flex flex-col gap-2">
            <h3>GSAP Animations</h3>
            <p class="text-zinc-400 leading-relaxed">
              Scroll-driven and interactive animations using GSAP and ScrollTrigger. Smooth, performant, and built to match your design
              intent precisely — not approximated.
            </p>
          </div>
        </div>
        <div class="card flex flex-col">
          <Icon name="lucide:layers" class="icon mb-8" />
          <div class="flex flex-col gap-2">
            <h3>Client-First Methodology</h3>
            <p class="text-zinc-400 leading-relaxed">
              All builds follow Webflow's Client-First naming convention — keeping sites clean, scalable, and easy for your team or clients
              to hand off and maintain.
            </p>
          </div>
        </div>
        <div class="card flex flex-col">
          <Icon name="lucide:building-2" class="icon mb-8" />
          <div class="flex flex-col gap-2">
            <h3>Enterprise Builds</h3>
            <p class="text-zinc-400 leading-relaxed">
              Multi-locale, multi-brand, or high-complexity builds. I've shipped enterprise-level Webflow sites that handle real scale,
              traffic, and editorial teams.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
