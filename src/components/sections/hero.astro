---
import Button from "../../components/Button.astro";
import { Icon } from "astro-icon/components";
---

<section class="bg-black text-white min-h-svh flex flex-col justify-end">
  <div class="padding-global pb-16 md:pb-24 pt-40">
    <div class="container flex flex-col gap-10">
      <div class="flex flex-col gap-6 max-w-5xl">
        <div class="flex items-center gap-2 w-fit bg-zinc-900 border border-zinc-800 rounded-full px-3 py-1.5">
          <span class="relative flex size-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex size-2 rounded-full bg-green-400"></span>
          </span>
          <span class="text-zinc-300 font-mono text-[10px] uppercase tracking-widest">Available for new projects</span>
        </div>
        <h1>
          Webflow development for agencies that demand precision.
        </h1>
      </div>
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 border-t border-zinc-800 pt-8">
        <p class="max-w-lg text-lg text-zinc-400 leading-relaxed">
          I partner with agencies and designers to bring their Webflow builds
          to life — on time, on spec, and built to scale.
        </p>
        <div class="flex gap-3 shrink-0">
          <Button url="mailto:hello@kevineiserman.com" text="Start a project"><Icon name="ph:arrow-right" class="size-4" /></Button>
          <Button url="#work" text="View work" variant="secondary" />
        </div>
      </div>
    </div>
  </div>
</section>
