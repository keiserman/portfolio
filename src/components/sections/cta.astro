---
import Button from "../Button.astro";
---

<section class="section bg-black text-white">
  <div class="padding-global">
    <div class="container">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-10">
        <div class="flex flex-col gap-6 max-w-2xl">
          <p class="text-zinc-400 font-mono text-sm uppercase tracking-widest">Get in touch</p>
          <h2>Have a Webflow project?<br />Let's talk.</h2>
          <p class="text-lg text-zinc-400 leading-relaxed">
            I'm currently taking on new agency partnerships. If you've got a
            project ready to build, reach out and let's see if we're a good fit.
          </p>
        </div>
        <div class="shrink-0">
          <Button url="mailto:hello@kevineiserman.com" text="Start a conversation" />
        </div>
      </div>
    </div>
  </div>
</section>
